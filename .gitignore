# ============================================================
# .gitignore - Files to exclude from version control
# ============================================================

# Terraform state files (contain sensitive data — never commit!)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform lock and plan files
.terraform.lock.hcl
*.tfplan

# Terraform working directory
.terraform/

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# AWS credentials (NEVER commit these)
*.pem
*.key
credentials
.aws/

# IDE / OS files
.DS_Store
.idea/
.vscode/
*.swp
